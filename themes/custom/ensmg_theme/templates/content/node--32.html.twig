          </div>
        </div>

      </div>{# end .ens-grid #}
    </div>
  </div>

  {# Wave white→navy #}
  <div class="ens-wave-sep ens-wave-sep--white-navy" aria-hidden="true">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M0,0 C480,60 960,0 1440,40 L1440,60 L0,60 Z" fill="#0f1c37"/>
    </svg>
  </div>

  {# ══════════════════════════════════════════
     CTA
  ══════════════════════════════════════════ #}
  <div class="ens-section ens-section--navy">
    <div class="ens-container">
      <div class="ens-cta ens-reveal">
        <div class="ens-cta-text">
          <span class="ens-cta-eyebrow">En savoir plus</span>
          <h2>Rejoindre l'ENSMG</h2>
          <p>Formations d'excellence, recherche et opportunités de carrière dans les géosciences.</p>
        </div>
        <div class="ens-cta-actions">
          <a href="/formation/ingenieur-geologue" class="btn-ensmg-primary">
            <i class="bi bi-mortarboard-fill"></i> Nos formations
          </a>
          <a href="/contact" class="btn-ensmg-outline-light">
            <i class="bi bi-chat-dots-fill"></i> Nous contacter
          </a>
        </div>
      </div>
    </div>
  </div>

  {# ══════════════════════════════════════════
     MODAL PROFIL ENSEIGNANT
  ══════════════════════════════════════════ #}
  <div class="ens-modal-overlay" id="ens-modal" role="dialog" aria-modal="true" aria-labelledby="ens-modal-name">
    <div class="ens-modal-box">
      <button class="ens-modal-close" id="ens-modal-close" aria-label="Fermer">
        <i class="bi bi-x-lg"></i>
      </button>
      <div class="ens-modal-header">
        <div class="ens-modal-avatar" id="ens-modal-avatar"></div>
        <div class="ens-modal-header-body">
          <div class="ens-modal-eyebrow" id="ens-modal-domain"></div>
          <h2 class="ens-modal-name" id="ens-modal-name"></h2>
          <p class="ens-modal-role" id="ens-modal-role"></p>
        </div>
      </div>
      <div class="ens-modal-content">
        <div class="ens-modal-spec" id="ens-modal-spec"></div>
        <p class="ens-modal-bio" id="ens-modal-bio"></p>
        <div class="ens-modal-tags" id="ens-modal-tags"></div>
      </div>
    </div>
  </div>

</div>{# end .ens-page #}
