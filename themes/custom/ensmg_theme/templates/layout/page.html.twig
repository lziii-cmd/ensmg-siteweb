{#
/**
 * @file
 * ENSMG Theme — Page Template
 * Bleu Marine & Or — UCAD Dakar
 */
#}
<!DOCTYPE html>
<html{{ html_attributes }}>
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    {{ head_title }}
    {{ head }}
    {# Bootstrap 5 CDN #}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    {# Bootstrap Icons #}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    {# Google Fonts #}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Source+Sans+3:ital,wght@0,300;0,400;0,600;0,700;1,400&display=swap">
    {{ styles }}
  </head>
  <body{{ attributes }}>
    {{ page_top }}

    {# Skip link #}
    <a href="#main-content" class="skip-link">Aller au contenu principal</a>

    <div class="layout-container">

      {# ── Header & Navigation ── #}
      <header class="site-header" role="banner">
        <div class="header-inner">

          {# Logo #}
          <a href="{{ path('<front>') }}" class="site-logo" rel="home">
            {% if page.header %}
              {{ page.header }}
            {% else %}
              <div class="site-logo-text">
                <span class="school-name">ENSMG</span>
                <span class="school-acronym">École des Mines &amp; Géologie · UCAD Dakar</span>
              </div>
            {% endif %}
          </a>

          {# Mobile toggle #}
          <button class="nav-toggle" aria-label="Ouvrir le menu" aria-expanded="false">
            <i class="bi bi-list" style="font-size:1.5rem;"></i>
            <span class="d-none d-sm-inline" style="font-size:.8rem;font-weight:600;">MENU</span>
          </button>

          {# Main navigation #}
          <nav class="site-nav" role="navigation" aria-label="Navigation principale" id="main-nav">
            {{ page.primary_menu }}
          </nav>

        </div>

        {# ── Bande fil d'Ariane — pages intérieures uniquement ── #}
        {% if not is_front and page.breadcrumb %}
          <div class="header-breadcrumb-bar">
            <div class="header-breadcrumb-inner">
              {{ page.breadcrumb }}
            </div>
          </div>
        {% endif %}

      </header>

      <main id="main-content" role="main" tabindex="-1">

        {# Messages #}
        {{ page.highlighted }}

        {# Hero region (only if block placed there) #}
        {% if page.hero %}
          {{ page.hero }}
        {% endif %}

        {# Admin tabs (local tasks) #}
        {% if page.pre_content %}
          <div class="pre-content-region">
            {{ page.pre_content }}
          </div>
        {% endif %}

        {# Featured top region #}
        {% if page.featured_top %}
          {{ page.featured_top }}
        {% endif %}

        {# Main content area #}
        <div class="page-wrapper{% if not page.sidebar_first and not page.sidebar_second %} full-width{% endif %}">

          {% if page.sidebar_first %}
            <aside class="page-sidebar" role="complementary">
              {{ page.sidebar_first }}
            </aside>
          {% endif %}

          <div class="page-content">
            {{ page.content }}
          </div>

          {% if page.sidebar_second %}
            <aside class="page-sidebar" role="complementary">
              {{ page.sidebar_second }}
            </aside>
          {% endif %}

        </div>

        {# Featured bottom region #}
        {% if page.featured_bottom %}
          {{ page.featured_bottom }}
        {% endif %}

      </main>

      {# ── Footer ── #}
      <footer class="site-footer" role="contentinfo">
        <div class="footer-grid">

          {# Col 1 — About #}
          <div class="footer-about">
            <div class="footer-logo">
              <div class="site-logo-text footer-logo-text">
                <span class="school-name">ENSMG</span>
                <span class="school-acronym">École des Mines &amp; Géologie · UCAD Dakar</span>
              </div>
            </div>
            <p>Former des ingénieurs et chercheurs de haut niveau dans les domaines des géosciences, du génie minier, du pétrole et de la géotechnique, au service du développement du Sénégal et de l'Afrique.</p>
            <div class="footer-social">
              <a href="#" aria-label="Facebook"><i class="bi bi-facebook"></i></a>
              <a href="#" aria-label="Twitter/X"><i class="bi bi-twitter-x"></i></a>
              <a href="#" aria-label="LinkedIn"><i class="bi bi-linkedin"></i></a>
              <a href="#" aria-label="YouTube"><i class="bi bi-youtube"></i></a>
            </div>
          </div>

          {# Col 2 — Liens rapides #}
          <div>
            <div class="footer-col-title">Navigation</div>
            {% if page.footer_first %}
              {{ page.footer_first }}
            {% else %}
              <ul class="footer-links">
                <li><a href="/formation">Formations</a></li>
                <li><a href="/admissions">Admissions</a></li>
                <li><a href="/recherches">Recherches</a></li>
                <li><a href="/enseignants">Enseignants</a></li>
                <li><a href="/actualites">Actualités</a></li>
                <li><a href="/contact">Contact</a></li>
              </ul>
            {% endif %}
          </div>

          {# Col 3 — Formations #}
          <div>
            <div class="footer-col-title">Formations</div>
            {% if page.footer_second %}
              {{ page.footer_second }}
            {% else %}
              <ul class="footer-links">
                <li><a href="/formation/ingenieur-geologue">Ingénieur Géologue</a></li>
                <li><a href="/formation/master-geotechnique">Master Géotechnique</a></li>
                <li><a href="/formation/licence-pro-geotechnique">Licence Pro Géotechnique</a></li>
                <li><a href="/formation/certification-mofi">Certification MOFI</a></li>
              </ul>
            {% endif %}
          </div>

          {# Col 4 — Contact #}
          <div>
            <div class="footer-col-title">Contact</div>
            {% if page.footer_third %}
              {{ page.footer_third }}
            {% else %}
              <div class="footer-contact-item">
                <span class="footer-contact-icon"><i class="bi bi-geo-alt-fill"></i></span>
                <span>Université Cheikh Anta Diop de Dakar<br>ENSMG — BP 5005 Dakar-Fann</span>
              </div>
              <div class="footer-contact-item">
                <span class="footer-contact-icon"><i class="bi bi-telephone-fill"></i></span>
                <span>+221 33 824 23 45</span>
              </div>
              <div class="footer-contact-item">
                <span class="footer-contact-icon"><i class="bi bi-envelope-fill"></i></span>
                <span>contact@ensmg.ucad.sn</span>
              </div>
              <div class="footer-contact-item">
                <span class="footer-contact-icon"><i class="bi bi-globe"></i></span>
                <span>www.ensmg.ucad.sn</span>
              </div>
            {% endif %}
          </div>

        </div>

        {# Footer bottom bar #}
        <div class="footer-bottom">
          {% if page.footer_bottom %}
            {{ page.footer_bottom }}
          {% else %}
            <div class="footer-bottom-inner">
              <span>© {{ "now"|date("Y") }} ENSMG — Université Cheikh Anta Diop de Dakar. Tous droits réservés.</span>
              <div class="d-flex gap-3 flex-wrap justify-content-center">
                <a href="/mentions-legales">Mentions légales</a>
                <a href="/politique-confidentialite">Confidentialité</a>
                <a href="/plan-du-site">Plan du site</a>
              </div>
            </div>
          {% endif %}
        </div>

      </footer>

    </div>{# end layout-container #}

    {{ page_bottom }}
    {{ scripts }}
    {# Bootstrap 5 JS #}
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
