{#
/**
 * @file
 * ENSMG Theme — Page (basic page) node template
 * Pleine largeur, sans sidebar
 */
#}
{% set classes = [
  'node',
  'node--type-' ~ node.bundle|clean_class,
  not node.isPublished() ? 'node--unpublished',
  view_mode ? 'node--view-mode-' ~ view_mode|clean_class,
] %}

<div class="inner-page-layout inner-page-layout--full">

  <article{{ attributes.addClass(classes) }}>

    {{ title_prefix }}
    {{ title_suffix }}

    {# Barre de progression lecture #}
    <div class="reading-progress-bar" id="readingProgress"></div>

    {# Corps de l'article #}
    <div class="inner-article-body inner-article-body--accordion">
      <div class="article-body-deco"></div>

      <div class="article-section-tag">
        <i class="bi bi-journal-text"></i>
        <span>Informations officielles</span>
      </div>

      <div{{ content_attributes.addClass('node__content') }}>
        {{ content }}
      </div>
    </div>

    {# Navigation bas de page #}
    <div class="inner-page-nav-bottom">
      <a href="javascript:history.back()" class="btn-back-page">
        <i class="bi bi-arrow-left-circle-fill"></i>
        <span>Retour</span>
      </a>
      <div class="share-bar">
        <span class="share-label">Partager :</span>
        <a href="#" class="share-btn share-fb" title="Facebook"><i class="bi bi-facebook"></i></a>
        <a href="#" class="share-btn share-li" title="LinkedIn"><i class="bi bi-linkedin"></i></a>
        <a href="#" class="share-btn share-tw" title="Twitter/X"><i class="bi bi-twitter-x"></i></a>
        <a href="#" class="share-btn share-mail" title="Email"><i class="bi bi-envelope-fill"></i></a>
      </div>
    </div>

  </article>

</div>
